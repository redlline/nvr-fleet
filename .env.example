# Copy to .env and fill in values before deploying
# Generate strong values: openssl rand -hex 32

# REQUIRED — server will warn and use ephemeral values if not set (sessions lost on restart)
ADMIN_TOKEN=
JWT_SECRET=

# REQUIRED — public hostname used for HLS/RTSP URLs
PUBLIC_HOST=cams.yourdomain.com

# MTX Toolkit UI auth (used by mtx-toolkit compose)
MTX_UI_USER=admin
MTX_UI_PASSWORD=

# MEDIAMTX internal credentials
MEDIAMTX_INTERNAL_PASS=
