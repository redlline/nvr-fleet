# NVR-Fleet — .env configuration
# Copy to .env and fill in all values before starting the stack.
# Generate secrets with: openssl rand -hex 32

# ── Required secrets ─────────────────────────────────────────────────────────
# Fleet-server will start with ephemeral random values if unset, but sessions
# will be lost on restart and a WARNING will appear in logs.
ADMIN_TOKEN=
JWT_SECRET=

# ── Public config ─────────────────────────────────────────────────────────────
PUBLIC_HOST=nvr.yourdomain.com

# ── MediaMTX credentials (all required) ──────────────────────────────────────
# MEDIAMTX_VIEWER_PASS: read-only password for RTSP/HLS viewer account.
# Must match the 'viewer' user in the generated mediamtx.yml.
MEDIAMTX_VIEWER_PASS=

# MEDIAMTX_API_PASS: password for fleet-server <-> mediamtx internal API.
# Protects the MediaMTX management API (port 9997).
MEDIAMTX_API_PASS=

# MEDIAMTX_PUBLISH_SECRET: HMAC secret for per-site publish passwords.
# Prevents guessing publish credentials from site IDs (which are visible in API).
# Without this, publish passwords fall back to predictable PASS_{site_id}.
MEDIAMTX_PUBLISH_SECRET=

# ── MTX Toolkit UI auth (used by docker-compose.mtx-toolkit.yml) ─────────────
MTX_UI_USER=admin
MTX_UI_PASSWORD=

# ── Optional overrides ────────────────────────────────────────────────────────
# JWT_EXPIRE_HOURS=24
# RTSP_PORT=8554
# DATABASE_URL=sqlite:///./fleet.db
# MEDIAMTX_API_USER=mediamtx-internal
