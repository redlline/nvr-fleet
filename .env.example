# Copy to .env and fill in real values before deploying
# Generate strong secrets with: openssl rand -hex 32

# ── Required secrets ─────────────────────────────────────────────────────────
# fleet-server now fails fast if the critical runtime secrets below are unset.
ADMIN_TOKEN=
JWT_SECRET=

# ── Required public config ───────────────────────────────────────────────────
PUBLIC_HOST=cams.yourdomain.com

# ── MediaMTX credentials ─────────────────────────────────────────────────────
# MEDIAMTX_VIEWER_PASS: read-only password for the 'viewer' account in MediaMTX.
# Used by: config_gen (mediamtx.yml), fleet-server (RTSP URLs), MTX Toolkit.
# Must match the 'viewer' user entry in mediamtx.yml.
MEDIAMTX_VIEWER_PASS=

# MEDIAMTX_INTERNAL_PASS: internal API password for fleet-server <-> mediamtx.
# Used by: fleet-server (API polling), MTX Toolkit backend.
MEDIAMTX_INTERNAL_PASS=

# ── MTX Toolkit UI auth ───────────────────────────────────────────────────────
# Protects the MTX Toolkit web UI on port 3001 with nginx basic auth.
MTX_UI_USER=admin
MTX_UI_PASSWORD=

# Optional, but strongly recommended so generated public URLs stay consistent.
PUBLIC_SCHEME=https
